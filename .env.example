# Database
DATABASE_URL=postgresql://quant_user:quant_pass@localhost:5432/quant_db
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════
# 数据源 API Tokens
# ═══════════════════════════════════════

# Tushare Pro Token (可选，注册获取: https://tushare.pro/register)
# 支持的数据: 日线、财务指标、资金流向、涨停股、指数等
# 免费额度: 5000积分/天，高级接口需更多积分
TUSHARE_TOKEN=your_tushare_token_here

# Paths
DATA_DIR=./data_storage
LOG_DIR=./logs

# Trading
INITIAL_CAPITAL=1000000
COMMISSION_RATE=0.00025
STAMP_DUTY=0.001
MIN_COMMISSION=5

# Schedule
MARKET_OPEN=09:30
MARKET_CLOSE=15:00
